{% comment %} Vault TCG — Homepage v2 {% endcomment %}

{%- assign new_arrivals    = collections[section.settings.new_arrivals_collection] -%}
{%- assign poke_collection = collections[section.settings.pokemon_collection] -%}
{%- assign op_collection   = collections[section.settings.onepiece_collection] -%}
{%- assign best_sellers    = collections[section.settings.collection_best_sellers] -%}

<!-- ═══════════════════════════════════════════════
     HERO SLIDER
     ═══════════════════════════════════════════════ -->
<div class="qc-hero" data-hero style="--hero-cards-w: {{ section.settings.hero_image_size | default: 24 }}rem">

  <!-- Slide 1 -->
  <div class="qc-hero__slide qc-hero__slide--poke is-active" data-slide="0" id="qc-hero-slide-0" role="tabpanel" aria-labelledby="qc-hero-dot-0">
    {% if section.settings.hero_slide_1_bg_image != blank %}
      {{ section.settings.hero_slide_1_bg_image | image_url: width: 1400 | image_tag: class: 'qc-hero__bg-img', loading: 'eager', alt: '' }}
      <div class="qc-hero__bg-overlay" aria-hidden="true"></div>
    {% endif %}
    <div class="qc-hero__glow qc-hero__glow--poke" aria-hidden="true"></div>

    <div class="qc-hero__cards{% if section.settings.hero_hide_image_mobile %} qc-hero__cards--mobile-hidden{% endif %}" aria-hidden="true">
      {% if section.settings.hero_slide_1_image != blank %}
        {{ section.settings.hero_slide_1_image | image_url: width: 400 | image_tag: class: 'qc-hero__img', loading: 'eager', alt: '' }}
      {% else %}
        <div class="qc-hero__card qc-hero__card--1"></div>
        <div class="qc-hero__card qc-hero__card--2"></div>
        <div class="qc-hero__card qc-hero__card--3"></div>
      {% endif %}
    </div>

    {% if section.settings.hero_badge_text != blank %}
      <div class="qc-hero__badge">
        <span class="qc-hero__badge-dot" aria-hidden="true"></span>
        <span class="qc-hero__badge-label">{{ section.settings.hero_badge_text }}</span>
      </div>
    {% endif %}

    <div class="qc-hero__text">
      <p class="qc-hero__eyebrow">
        <span class="qc-hero__eyebrow-line" aria-hidden="true"></span>
        CN Exclusives · Ships from AU
      </p>
      <h1 class="qc-hero__headline">
        {{ section.settings.hero_slide_1_headline | newline_to_br }}
      </h1>
      <p class="qc-hero__sub">{{ section.settings.hero_slide_1_sub }}</p>
      <div class="qc-hero__ctas">
        <a href="{{ section.settings.hero_slide_1_cta_url }}" class="qc-btn qc-btn--primary">
          {{ section.settings.hero_slide_1_cta_label }}
        </a>
        <a href="/collections" class="qc-btn qc-btn--ghost">Browse All</a>
      </div>
    </div>
  </div>

  <!-- Slide 2 -->
  <div class="qc-hero__slide qc-hero__slide--op" data-slide="1" id="qc-hero-slide-1" role="tabpanel" aria-labelledby="qc-hero-dot-1" aria-hidden="true">
    {% if section.settings.hero_slide_2_bg_image != blank %}
      {{ section.settings.hero_slide_2_bg_image | image_url: width: 1400 | image_tag: class: 'qc-hero__bg-img', loading: 'lazy', alt: '' }}
      <div class="qc-hero__bg-overlay" aria-hidden="true"></div>
    {% endif %}
    <div class="qc-hero__glow qc-hero__glow--op" aria-hidden="true"></div>

    <div class="qc-hero__cards{% if section.settings.hero_hide_image_mobile %} qc-hero__cards--mobile-hidden{% endif %}" aria-hidden="true">
      {% if section.settings.hero_slide_2_image != blank %}
        {{ section.settings.hero_slide_2_image | image_url: width: 400 | image_tag: class: 'qc-hero__img', loading: 'lazy', alt: '' }}
      {% else %}
        <div class="qc-hero__card qc-hero__card--op-1"></div>
        <div class="qc-hero__card qc-hero__card--op-2"></div>
        <div class="qc-hero__card qc-hero__card--op-3"></div>
      {% endif %}
    </div>

    <div class="qc-hero__text">
      <p class="qc-hero__eyebrow">
        <span class="qc-hero__eyebrow-line" aria-hidden="true"></span>
        One Piece CN · Direct Import
      </p>
      <h1 class="qc-hero__headline">
        {{ section.settings.hero_slide_2_headline | newline_to_br }}
      </h1>
      <p class="qc-hero__sub">{{ section.settings.hero_slide_2_sub }}</p>
      <div class="qc-hero__ctas">
        <a href="{{ section.settings.hero_slide_2_cta_url }}" class="qc-btn qc-btn--primary">
          {{ section.settings.hero_slide_2_cta_label }}
        </a>
        <a href="/collections" class="qc-btn qc-btn--ghost">Browse All</a>
      </div>
    </div>
  </div>

  <!-- Slide dots -->
  <div class="qc-hero__dots" role="tablist" aria-label="Hero slides">
    <button class="qc-hero__dot is-active" data-dot="0" role="tab" id="qc-hero-dot-0" aria-label="Slide 1 of 2" aria-selected="true" aria-controls="qc-hero-slide-0"></button>
    <button class="qc-hero__dot" data-dot="1" role="tab" id="qc-hero-dot-1" aria-label="Slide 2 of 2" aria-selected="false" aria-controls="qc-hero-slide-1"></button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     TRUST MARQUEE
     ═══════════════════════════════════════════════ -->
<div class="qc-trust-marquee" aria-hidden="true">
  <div class="qc-trust-marquee__track">
    {%- for i in (1..2) -%}
      <span class="qc-trust-marquee__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        100% Authentic CN Import
      </span>
      <span class="qc-trust-marquee__sep" aria-hidden="true"></span>
      <span class="qc-trust-marquee__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        Ships from Melbourne
      </span>
      <span class="qc-trust-marquee__sep" aria-hidden="true"></span>
      <span class="qc-trust-marquee__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        PSA · BGS · CGC Verified
      </span>
      <span class="qc-trust-marquee__sep" aria-hidden="true"></span>
      <span class="qc-trust-marquee__item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Real Collector Support
      </span>
      <span class="qc-trust-marquee__sep" aria-hidden="true"></span>
    {%- endfor -%}
  </div>
</div>

<!-- ═══════════════════════════════════════════════
     JUST LANDED
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-default" id="new-arrivals">
  <div class="qc-home-section__hd">
    <div>
      <h2 class="qc-home-section__title">New Arrivals</h2>
    </div>
    {% if new_arrivals != blank %}
      <a href="{{ new_arrivals.url }}" class="qc-home-section__link">
        View all
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    {% endif %}
  </div>

  <div class="qc-h-scroll" role="list">
    {% if new_arrivals != blank and new_arrivals.products.size > 0 %}
      {%- assign limit = section.settings.new_arrivals_count | default: 8 -%}
      {% for product in new_arrivals.products limit: limit %}
        {%- assign zone = product.metafields.custom.game | default: '' -%}
        <div class="qc-scroll-pc" role="listitem">
          <a href="{{ product.url }}" class="qc-scroll-pc__inner" aria-label="{{ product.title }}">
            <div class="qc-scroll-pc__img-wrap">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, class: 'qc-scroll-pc__img' }}
              {% else %}
                <div class="qc-scroll-pc__img qc-scroll-pc__img--placeholder qc-scroll-pc__img--{{ zone }}"></div>
              {% endif %}
              <span class="qc-scroll-pc__badge qc-scroll-pc__badge--{{ zone }}">CN</span>
            </div>
            <div class="qc-scroll-pc__body">
              <p class="qc-scroll-pc__meta">{{ zone | upcase | replace: '-', ' ' }}</p>
              <p class="qc-scroll-pc__name">{{ product.title }}</p>
              <p class="qc-scroll-pc__price">{{ product.price | money }}</p>
            </div>
          </a>
        </div>
      {% endfor %}
    {% else %}
      <p class="qc-home-section__empty">Products coming soon.</p>
    {% endif %}
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     FAN FAVOURITES
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-surface" id="fan-favourites" data-tabs>
  <div class="qc-home-section__hd">
    <div>
      <h2 class="qc-home-section__title">Fan Favourites</h2>
    </div>
  </div>

  <div class="qc-ff-tabs" role="tablist" aria-label="Fan Favourites categories">
    <button class="qc-ff-tab is-active" data-tab="0" role="tab" aria-selected="true" aria-controls="qc-ff-panel-0">Best Sellers</button>
    <button class="qc-ff-tab" data-tab="1" role="tab" aria-selected="false" aria-controls="qc-ff-panel-1">Pokémon CN</button>
    <button class="qc-ff-tab" data-tab="2" role="tab" aria-selected="false" aria-controls="qc-ff-panel-2">One Piece CN</button>
  </div>

  {%- assign ff_limit = section.settings.favourites_count | default: 6 -%}

  <div id="qc-ff-panel-0" class="qc-ff-panel" data-panel="0" role="tabpanel">
    <div class="qc-h-scroll" role="list">
      {% if best_sellers != blank and best_sellers.products.size > 0 %}
        {% for product in best_sellers.products limit: ff_limit %}
          {%- assign zone = product.metafields.custom.game | default: '' -%}
          <div class="qc-scroll-pc" role="listitem">
            <a href="{{ product.url }}" class="qc-scroll-pc__inner" aria-label="{{ product.title }}">
              <div class="qc-scroll-pc__img-wrap qc-scroll-pc__img-wrap--tall">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, class: 'qc-scroll-pc__img' }}
                {% else %}
                  <div class="qc-scroll-pc__img qc-scroll-pc__img--placeholder qc-scroll-pc__img--{{ zone }}"></div>
                {% endif %}
                <span class="qc-scroll-pc__badge qc-scroll-pc__badge--{{ zone }}">CN</span>
              </div>
              <div class="qc-scroll-pc__body">
                <p class="qc-scroll-pc__meta">{{ zone | upcase | replace: '-', ' ' }}</p>
                <p class="qc-scroll-pc__name">{{ product.title }}</p>
                <p class="qc-scroll-pc__price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <p class="qc-home-section__empty">No best sellers set yet.</p>
      {% endif %}
    </div>
  </div>

  <div id="qc-ff-panel-1" class="qc-ff-panel" data-panel="1" role="tabpanel" hidden>
    <div class="qc-h-scroll" role="list">
      {% if poke_collection != blank and poke_collection.products.size > 0 %}
        {% for product in poke_collection.products limit: ff_limit %}
          <div class="qc-scroll-pc" role="listitem">
            <a href="{{ product.url }}" class="qc-scroll-pc__inner" aria-label="{{ product.title }}">
              <div class="qc-scroll-pc__img-wrap qc-scroll-pc__img-wrap--tall">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, class: 'qc-scroll-pc__img' }}
                {% else %}
                  <div class="qc-scroll-pc__img qc-scroll-pc__img--placeholder qc-scroll-pc__img--pokemon"></div>
                {% endif %}
                <span class="qc-scroll-pc__badge qc-scroll-pc__badge--pokemon">CN</span>
              </div>
              <div class="qc-scroll-pc__body">
                <p class="qc-scroll-pc__meta">Pokémon CN</p>
                <p class="qc-scroll-pc__name">{{ product.title }}</p>
                <p class="qc-scroll-pc__price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <p class="qc-home-section__empty">Products coming soon.</p>
      {% endif %}
    </div>
  </div>

  <div id="qc-ff-panel-2" class="qc-ff-panel" data-panel="2" role="tabpanel" hidden>
    <div class="qc-h-scroll" role="list">
      {% if op_collection != blank and op_collection.products.size > 0 %}
        {% for product in op_collection.products limit: ff_limit %}
          <div class="qc-scroll-pc" role="listitem">
            <a href="{{ product.url }}" class="qc-scroll-pc__inner" aria-label="{{ product.title }}">
              <div class="qc-scroll-pc__img-wrap qc-scroll-pc__img-wrap--tall">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, class: 'qc-scroll-pc__img' }}
                {% else %}
                  <div class="qc-scroll-pc__img qc-scroll-pc__img--placeholder qc-scroll-pc__img--one-piece"></div>
                {% endif %}
                <span class="qc-scroll-pc__badge qc-scroll-pc__badge--one-piece">CN</span>
              </div>
              <div class="qc-scroll-pc__body">
                <p class="qc-scroll-pc__meta">One Piece CN</p>
                <p class="qc-scroll-pc__name">{{ product.title }}</p>
                <p class="qc-scroll-pc__price">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      {% else %}
        <p class="qc-home-section__empty">Products coming soon.</p>
      {% endif %}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     BROWSE BY CATEGORY
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-subtle" id="browse-categories">
  <div class="qc-home-section__hd">
    <div>
      <h2 class="qc-home-section__title">Browse by Category</h2>
    </div>
  </div>

  <div class="qc-cat-grid" style="--cat-icon: {{ section.settings.cat_icon_size | default: 28 }}px">

    <!-- Pokémon CN — full width -->
    {% if poke_collection != blank %}
      <a href="{{ poke_collection.url }}" class="qc-cat-card qc-cat-card--poke qc-cat-card--full" aria-label="Browse Pokémon CN">
        {% if section.settings.cat_poke_image != blank %}
          {{ section.settings.cat_poke_image | image_url: width: 600 | image_tag: class: 'qc-cat-card__bg-img', loading: 'lazy', alt: '' }}
        {% endif %}
        <div class="qc-cat-card__icon" aria-hidden="true">
          {% if section.settings.cat_poke_icon != blank %}
            {{ section.settings.cat_poke_icon | image_url: width: 56 | image_tag: loading: 'lazy', alt: '' }}
          {% else %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {% endif %}
        </div>
        <p class="qc-cat-card__name">Pokémon CN</p>
        <p class="qc-cat-card__sub">Booster boxes, displays and sealed product</p>
        <span class="qc-cat-card__arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </a>
    {% endif %}

    <!-- One Piece CN -->
    {% if op_collection != blank %}
      <a href="{{ op_collection.url }}" class="qc-cat-card qc-cat-card--op" aria-label="Browse One Piece CN">
        {% if section.settings.cat_op_image != blank %}
          {{ section.settings.cat_op_image | image_url: width: 400 | image_tag: class: 'qc-cat-card__bg-img', loading: 'lazy', alt: '' }}
        {% endif %}
        <div class="qc-cat-card__icon" aria-hidden="true">
          {% if section.settings.cat_op_icon != blank %}
            {{ section.settings.cat_op_icon | image_url: width: 56 | image_tag: loading: 'lazy', alt: '' }}
          {% else %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          {% endif %}
        </div>
        <p class="qc-cat-card__name">One Piece CN</p>
        <p class="qc-cat-card__sub">Sets and exclusives</p>
        <span class="qc-cat-card__arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </a>
    {% endif %}

    <!-- New Arrivals -->
    {% if new_arrivals != blank %}
      <a href="{{ new_arrivals.url }}" class="qc-cat-card qc-cat-card--new" aria-label="Browse New Arrivals">
        {% if section.settings.cat_new_image != blank %}
          {{ section.settings.cat_new_image | image_url: width: 400 | image_tag: class: 'qc-cat-card__bg-img', loading: 'lazy', alt: '' }}
        {% endif %}
        <div class="qc-cat-card__icon" aria-hidden="true">
          {% if section.settings.cat_new_icon != blank %}
            {{ section.settings.cat_new_icon | image_url: width: 56 | image_tag: loading: 'lazy', alt: '' }}
          {% else %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endif %}
        </div>
        <p class="qc-cat-card__name">New Arrivals</p>
        <p class="qc-cat-card__sub">Just landed this week</p>
        <span class="qc-cat-card__arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      </a>
    {% endif %}

  </div>
</section>

<!-- ═══════════════════════════════════════════════
     CN EXCLUSIVES EXPLAINER
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-dark" id="cn-explainer">
  <div class="qc-home-section__hd">
    <div>
      <p class="qc-home-section__eyebrow" style="color:var(--accent)">
        <span class="qc-home-section__eyebrow-line" aria-hidden="true"></span>
        About CN exclusives
      </p>
      <h2 class="qc-home-section__title" style="color:oklch(98% 0.003 90)">Why collectors seek them out</h2>
    </div>
  </div>
  <p class="qc-explain__intro">Chinese-market releases are a different world from what's sold in English-speaking countries.</p>

  <div class="qc-explain-cards">

    <div class="qc-explain-card">
      <div class="qc-explain-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
      </div>
      <div>
        <p class="qc-explain-card__title">{{ section.settings.exp_1_title }}</p>
        <p class="qc-explain-card__desc">{{ section.settings.exp_1_desc }}</p>
      </div>
    </div>

    <div class="qc-explain-card">
      <div class="qc-explain-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div>
        <p class="qc-explain-card__title">{{ section.settings.exp_2_title }}</p>
        <p class="qc-explain-card__desc">{{ section.settings.exp_2_desc }}</p>
      </div>
    </div>

    <div class="qc-explain-card">
      <div class="qc-explain-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </div>
      <div>
        <p class="qc-explain-card__title">{{ section.settings.exp_3_title }}</p>
        <p class="qc-explain-card__desc">{{ section.settings.exp_3_desc }}</p>
      </div>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SOCIAL PROOF
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-subtle" id="reviews">
  <div class="qc-home-section__hd">
    <div>
      <h2 class="qc-home-section__title">What They're Saying</h2>
    </div>
  </div>

  <div class="qc-h-scroll qc-reviews-scroll" role="list">

    {%- assign reviews = 'review_1,review_2,review_3' | split: ',' -%}
    {% for review_key in reviews %}
      {%- assign name_key  = review_key | append: '_name' -%}
      {%- assign quote_key = review_key | append: '_quote' -%}
      {%- assign initials  = section.settings[name_key] | split: ' ' | map: 'first' | join: '' | upcase | truncate: 2, '' -%}
      {% if section.settings[quote_key] != blank %}
        <div class="qc-review-card" role="listitem">
          <div class="qc-review-card__stars" aria-label="5 stars">
            {% for i in (1..5) %}
              <svg width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path fill="var(--accent)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </div>
          <blockquote class="qc-review-card__quote">{{ section.settings[quote_key] }}</blockquote>
          <div class="qc-review-card__author">
            <div class="qc-review-card__avatar" aria-hidden="true">{{ initials }}</div>
            <div>
              <p class="qc-review-card__name">{{ section.settings[name_key] }}</p>
              <p class="qc-review-card__verified">Verified buyer</p>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</section>

<!-- ═══════════════════════════════════════════════
     NEWSLETTER
     ═══════════════════════════════════════════════ -->
<section class="qc-home-section qc-home-section--bg-forest qc-newsletter" id="newsletter">
  <div class="qc-newsletter__glow" aria-hidden="true"></div>
  <p class="qc-newsletter__eyebrow">
    <span class="qc-newsletter__eyebrow-line" aria-hidden="true"></span>
    Drop alerts
  </p>
  <h2 class="qc-newsletter__title">{{ section.settings.newsletter_headline }}</h2>
  <p class="qc-newsletter__sub">{{ section.settings.newsletter_sub }}</p>

  <form class="qc-newsletter__form" data-newsletter-form action="/contact#contact_form" method="post" accept-charset="UTF-8">
    <input type="hidden" name="form_type" value="customer">
    <input type="hidden" name="utf8" value="✓">
    <input type="hidden" name="contact[tags]" value="newsletter">
    <label for="qc-nl-email" class="visually-hidden">Email address</label>
    <input
      id="qc-nl-email"
      class="qc-newsletter__input"
      type="email"
      name="contact[email]"
      placeholder="your@email.com"
      required
      autocomplete="email"
    >
    <button class="qc-btn qc-btn--nl" type="submit" data-newsletter-btn>
      {{ section.settings.newsletter_cta_label }}
    </button>
  </form>
  <p class="qc-newsletter__fine">No spam. Unsubscribe any time.</p>
</section>

