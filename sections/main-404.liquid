<div class="qc-404">
  <div class="qc-404__inner">
    <svg class="qc-404__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      <line x1="11" y1="8" x2="11" y2="12"/>
      <line x1="11" y1="16" x2="11.01" y2="16"/>
    </svg>
    <h1 class="qc-404__heading">Page not found</h1>
    <p class="qc-404__body">The page you're looking for doesn't exist or has been moved.</p>
    <div class="qc-404__actions">
      <a href="/" class="qc-404__btn qc-404__btn--primary">Back to Home</a>
      <a href="/collections/all" class="qc-404__btn qc-404__btn--secondary">Browse All Products</a>
    </div>
  </div>
</div>

<style>
.qc-404 {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-8) var(--space-4);
  text-align: center;
}
.qc-404__inner {
  max-width: 480px;
}
.qc-404__icon {
  width: 56px;
  height: 56px;
  color: var(--fg-muted);
  margin-bottom: var(--space-5);
}
.qc-404__heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 6vw, 3.5rem);
  letter-spacing: 0.04em;
  color: var(--fg);
  margin: 0 0 var(--space-3);
}
.qc-404__body {
  font-size: 1rem;
  color: var(--fg-muted);
  line-height: 1.6;
  margin: 0 0 var(--space-6);
}
.qc-404__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  justify-content: center;
}
.qc-404__btn {
  display: inline-flex;
  align-items: center;
  height: 48px;
  padding: 0 var(--space-5);
  border-radius: 4px;
  font-family: var(--font-display);
  font-size: 1rem;
  letter-spacing: 0.06em;
  text-decoration: none;
  transition: opacity 0.15s ease;
}
.qc-404__btn:hover { opacity: 0.85; }
.qc-404__btn--primary {
  background: var(--forest);
  color: oklch(97% 0.008 88);
}
.qc-404__btn--secondary {
  background: transparent;
  color: var(--fg);
  border: 1px solid var(--border);
}
</style>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-main-404"
}
{% endschema %}
