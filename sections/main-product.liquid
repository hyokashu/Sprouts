{% comment %} Qilin Cards — Product page (sealed TCG products) {% endcomment %}

{%- liquid
  assign game = product.metafields.custom.game.value
  assign product_type_tcg = product.metafields.custom.product_type_tcg.value
  assign set_name = product.metafields.custom.set_name.value
  assign edition = product.metafields.custom.edition.value
  assign current_variant = product.selected_or_first_available_variant

  assign zone_class = ''
  if game == 'pokemon'
    assign zone_class = 'zone-pokemon'
  elsif game == 'one-piece'
    assign zone_class = 'zone-one-piece'
  endif
-%}

<main id="main-content" class="qc-product {{ zone_class }}">
  <div class="container">
    <div class="qc-product__inner">

      <!-- ── Media column ─────────────────────────────────── -->
      <div class="qc-product__media">
        <div class="qc-product__main-image" id="qc-main-image">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              width="1200"
              height="{{ 1200 | divided_by: product.featured_image.aspect_ratio | round }}"
              loading="eager"
              id="qc-main-img"
            >
          {% else %}
            <div style="
              width:100%;height:100%;
              display:flex;align-items:center;justify-content:center;
              flex-direction:column;gap:1rem;
              color:var(--fg-muted);
            ">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="m8 21 4-4 4 4M12 17v4"/>
              </svg>
              <span class="text-small">No image</span>
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
        <ul class="qc-product__thumbnails">
          {% for image in product.images limit: 6 %}
            <li>
              <button
                class="qc-product__thumb {% if forloop.first %}is-active{% endif %}"
                data-src="{{ image | image_url: width: 1200 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | escape }}"
                  width="120"
                  height="120"
                  loading="lazy"
                >
              </button>
            </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>

      <!-- ── Info column ──────────────────────────────────── -->
      <div class="qc-product__info">

        <!-- Badges -->
        <div class="qc-product__badges">
          {% if set_name %}
            <span class="badge badge--subtle">{{ set_name }}</span>
          {% endif %}
          {% if edition %}
            <span class="badge badge--subtle">{{ edition }}</span>
          {% endif %}
          {% if game == 'pokemon' or game == 'one-piece' %}
            <span class="badge badge--cn">CN Exclusive</span>
          {% endif %}
        </div>

        <h1 class="qc-product__title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="qc-product__price-block">
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="qc-product__price-compare">{{ current_variant.compare_at_price | money }}</span>
            <span class="qc-product__price">{{ current_variant.price | money }}</span>
            <span class="qc-product__price-save">
              Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
            </span>
          {% else %}
            <span class="qc-product__price">{{ current_variant.price | money }}</span>
          {% endif %}
        </div>

        <!-- Add to cart form -->
        {% form 'product', product, id: 'qc-product-form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- comment -%}Hidden properties for cart drawer thumbnail / display{%- endcomment -%}
          <input type="hidden" name="properties[_product_type]" value="{{ product_type_tcg }}">
          <input type="hidden" name="properties[_set_name]" value="{{ set_name }}">
          <input type="hidden" name="properties[_game]" value="{{ game }}">

          <div class="qc-product__form">

            <!-- Variants (if more than one) -->
            {% unless product.has_only_default_variant %}
              {% for option in product.options_with_values %}
                <div>
                  <label
                    for="option-{{ option.position }}"
                    style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.5rem;"
                  >
                    {{ option.name }}
                  </label>
                  <select
                    id="option-{{ option.position }}"
                    name="option{{ option.position }}"
                    style="
                      appearance:none;
                      width:100%;
                      padding:0.75rem 1rem;
                      border:1.5px solid var(--border);
                      border-radius:var(--radius);
                      font-size:0.9375rem;
                      font-family:var(--font-body);
                      color:var(--fg);
                      background:var(--surface);
                      min-height:44px;
                    "
                  >
                    {% for value in option.values %}
                      <option value="{{ value }}" {% if value == option.selected_value %}selected{% endif %}>
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            {% endunless %}

            <!-- Quantity -->
            <div>
              <label style="display:block;font-size:0.875rem;font-weight:600;margin-bottom:0.5rem;">Quantity</label>
              <div class="qc-qty">
                <button type="button" class="qc-qty__btn" id="qc-qty-dec" aria-label="Decrease quantity">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
                <input
                  type="number"
                  id="qc-qty"
                  name="quantity"
                  value="1"
                  min="1"
                  max="{{ current_variant.inventory_quantity }}"
                  class="qc-qty__input"
                  aria-label="Quantity"
                >
                <button type="button" class="qc-qty__btn" id="qc-qty-inc" aria-label="Increase quantity">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
              </div>
            </div>

            <!-- Add to cart (shown when in stock) -->
            {% if current_variant.available %}
              <button type="submit" class="qc-add-to-cart">Add to Cart</button>
            {% endif %}

          </div>
        {% endform %}

        <!-- Out-of-stock notification (shown when unavailable) -->
        {% unless current_variant.available %}
          <div class="qc-oos" data-oos-wrapper>
            <div class="qc-oos__status">
              <span class="qc-oos__dot" aria-hidden="true"></span>
              Sold out
            </div>
            <button
              class="qc-oos__toggle"
              id="qc-oos-toggle"
              data-oos-toggle="qc-oos-form"
              aria-expanded="false"
              aria-controls="qc-oos-form"
            >
              Notify Me When Available
            </button>
            <div class="qc-oos__form-wrap" id="qc-oos-form" aria-hidden="true">
              {% form 'contact', id: 'qc-oos-contact', data-oos-form: '' %}
                <input type="hidden" name="contact[subject]" value="Back in Stock: {{ product.title | escape }}">
                <input type="hidden" name="contact[body]" value="Please notify me when {{ product.title | escape }} (variant {{ current_variant.id }}) is back in stock.">
                <div class="qc-oos__form-inner">
                  <div class="qc-oos__row">
                    <input
                      type="email"
                      name="contact[email]"
                      class="qc-oos__input"
                      placeholder="your@email.com"
                      aria-label="Email address for restock notification"
                      autocomplete="email"
                      required
                    >
                    <button type="submit" class="qc-oos__submit">Notify Me</button>
                  </div>
                  <p class="qc-oos__hint">One email when back in stock. No spam.</p>
                </div>
              {% endform %}
              <div class="qc-oos__success" data-oos-success style="display:none" role="status">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span>You're on the list — we'll email you at <strong data-oos-email></strong> when this is back.</span>
              </div>
            </div>
          </div>
        {% endunless %}

        <!-- CN Callout -->
        <div class="qc-callout">
          <svg class="qc-callout__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <div>
            <p class="qc-callout__title">Why Chinese edition?</p>
            <p class="qc-callout__body">
              Chinese-market releases often feature exclusive artwork, alternate borders, and print runs unavailable in Western markets. Each item is sourced directly and verified authentic.
            </p>
          </div>
        </div>

        <!-- Product details -->
        {% if product.description != blank or set_name or edition or game %}
        <div>
          <h2 class="text-h3" style="margin-bottom:var(--space-4);">Product Details</h2>
          <table class="qc-details-table">
            {% if game %}
            <tr>
              <th scope="row">Game</th>
              <td>{% if game == 'pokemon' %}Pokémon{% elsif game == 'one-piece' %}One Piece{% else %}{{ game }}{% endif %}</td>
            </tr>
            {% endif %}
            {% if set_name %}
            <tr>
              <th scope="row">Set</th>
              <td>{{ set_name }}</td>
            </tr>
            {% endif %}
            {% if edition %}
            <tr>
              <th scope="row">Edition</th>
              <td>{{ edition }}</td>
            </tr>
            {% endif %}
            {% if product_type_tcg %}
            <tr>
              <th scope="row">Type</th>
              <td>{{ product_type_tcg | capitalize }}</td>
            </tr>
            {% endif %}
            <tr>
              <th scope="row">Language</th>
              <td>Simplified Chinese (CN)</td>
            </tr>
            <tr>
              <th scope="row">Condition</th>
              <td>Factory sealed</td>
            </tr>
          </table>
        </div>
        {% endif %}

        {% if product.description != blank %}
        <div>
          <h2 class="text-h3" style="margin-bottom:var(--space-3);">Description</h2>
          <div class="text-body" style="max-width:65ch;color:var(--fg-muted);">
            {{ product.description }}
          </div>
        </div>
        {% endif %}

      </div>
    </div>
  </div>
</main>

<!-- ── Related products ──────────────────────────────────────── -->
{% assign related_collection = collections[game] %}
{% if related_collection and related_collection.products.size > 1 %}
<section class="qc-product__related {{ zone_class }}">
  <div class="container">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-8);flex-wrap:wrap;gap:1rem;">
      <h2 class="text-h2">You May Also Like</h2>
      <a href="/collections/{{ game }}" class="btn btn--outline" style="flex-shrink:0;">View all</a>
    </div>
    <div class="product-grid">
      {% for related in related_collection.products limit: 4 %}
        {% unless related.id == product.id %}
          {% render 'product-card', product: related %}
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<script>
(function () {
  // ── Thumbnail gallery ──────────────────────────────────────
  const mainImg = document.getElementById('qc-main-img');
  const thumbs  = document.querySelectorAll('.qc-product__thumb');

  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      if (mainImg) mainImg.src = thumb.dataset.src;
      thumbs.forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
    });
  });

  // ── Quantity stepper ───────────────────────────────────────
  const qtyInput = document.getElementById('qc-qty');
  const decBtn   = document.getElementById('qc-qty-dec');
  const incBtn   = document.getElementById('qc-qty-inc');

  if (qtyInput && decBtn && incBtn) {
    function syncStepperBtns() {
      const val = parseInt(qtyInput.value, 10);
      const max = parseInt(qtyInput.max, 10);
      decBtn.disabled = val <= 1;
      incBtn.disabled = max > 0 && val >= max;
    }
    syncStepperBtns();

    decBtn.addEventListener('click', function () {
      const val = parseInt(qtyInput.value, 10);
      if (val > 1) { qtyInput.value = val - 1; syncStepperBtns(); }
    });
    incBtn.addEventListener('click', function () {
      const val = parseInt(qtyInput.value, 10);
      const max = parseInt(qtyInput.max, 10);
      if (!max || val < max) { qtyInput.value = val + 1; syncStepperBtns(); }
    });
    qtyInput.addEventListener('change', syncStepperBtns);
  }

  // ── Add to cart → open drawer (not page reload) ───────────
  const atcForm = document.getElementById('qc-product-form');
  if (atcForm && window.QilinCart) {
    atcForm.addEventListener('submit', function (e) {
      e.preventDefault();
      const variantId  = atcForm.querySelector('[name="id"]').value;
      const qty        = parseInt(atcForm.querySelector('[name="quantity"]')?.value || '1', 10);
      const properties = {};
      atcForm.querySelectorAll('input[name^="properties["]').forEach(function (input) {
        const key = input.name.replace(/^properties\[(.+)\]$/, '$1');
        properties[key] = input.value;
      });
      QilinCart.add(variantId, qty, properties);
    });
  }
})();
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-main-product"
}
{% endschema %}
